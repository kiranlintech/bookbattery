pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        TOMCAT_USER = "ubuntu"
        TOMCAT_HOST = "65.0.94.76"
        TOMCAT_DIR  = "/opt/tomcat"
        WAR_NAME    = "bookbattery.war"
        SSH_CRED    = "jenkins_github_id"
    }

    stages {

        stage('Cleanup') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                git branch: 'deployment',
                    url: 'git@github.com:kiranlintech/bookbattery.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Archive WAR') {
            steps {
                archiveArtifacts artifacts: 'target/*.war', fingerprint: true
            }
        }

        stage('Stop Tomcat') {
            steps {
                sshagent([env.SSH_CRED]) {
                    sh """
                    ssh -o StrictHostKeyChecking=no ${TOMCAT_USER}@${TOMCAT_HOST} '
                        if [ -x "${TOMCAT_DIR}/bin/shutdown.sh" ]; then
                            ${TOMCAT_DIR}/bin/shutdown.sh || true
                            sleep 10
                        else
                            echo "Tomcat shutdown script not found, skipping stop"
                        fi
                    '
                    """
                }
            }
        }

        stage('Deploy WAR to Tomcat') {
            steps {
                sshagent([env.SSH_CRED]) {
                    sh """
                    if [ ! -f target/${WAR_NAME} ]; then
                        echo "WAR file not found!"
                        exit 1
                    fi

                    ssh -o StrictHostKeyChecking=no ${TOMCAT_USER}@${TOMCAT_HOST} '
                        rm -rf ${TOMCAT_DIR}/webapps/bookbattery*
                    '

                    scp -o StrictHostKeyChecking=no \
                        target/${WAR_NAME} \
                        ${TOMCAT_USER}@${TOMCAT_HOST}:${TOMCAT_DIR}/webapps/
                    """
                }
            }
        }

        stage('Start Tomcat') {
            steps {
                sshagent([env.SSH_CRED]) {
                    sh """
                    ssh -o StrictHostKeyChecking=no ${TOMCAT_USER}@${TOMCAT_HOST} '
                        ${TOMCAT_DIR}/bin/startup.sh
                    '
                    """
                }
            }
        }
    }

    post {
        success {
            echo "WAR deployed and Tomcat started successfully"
        }
        failure {
            echo "Deployment failed"
        }
    }
}
