pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'terra-jenk-ansi-mysql',
                    url: 'https://github.com/kiranlintech/bookbattery.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Deploy to Tomcat') {
            steps {
                sh '''
                scp -o StrictHostKeyChecking=no target/*.war ubuntu@10.0.1.38:/var/lib/tomcat8/webapps/bookbattery.war
                ssh ubuntu@10.0.1.38 "sudo systemctl restart tomcat8"
                '''
            }
        }
    }
}
